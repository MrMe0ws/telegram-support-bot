BOT_TOKEN=
# ID супергруппы с включёнными темами (forum), бот — админ с правом управлять топиками
SUPPORT_GROUP_ID=
# Через запятую: админы (доступ к /close в топике, /block, /unblock)
ADMIN_IDS=

# Важно: в @BotFather для бота выполните /setprivacy → Disable,
# иначе бот не получает обычные сообщения из группы и ответы саппорта не доходят до клиента.

# Уровень логов в консоль: DEBUG, INFO, WARNING, ERROR, CRITICAL (по умолчанию WARNING)
# Строки aiogram «Update … is handled» скрыты, пока не выставить LOG_LEVEL=DEBUG
LOG_LEVEL=WARNING

# SQLite в контейнере по умолчанию
DATABASE_URL=sqlite+aiosqlite:////data/support.db

# Плейсхолдеры: {username}, {ticket_id}, {uid}, {name}
TOPIC_NAME_TEMPLATE={username} · {ticket_id}

# Тексты UI: каталог texts/<BOT_LOCALE> (по умолчанию ru)
BOT_LOCALE=ru
# В Docker задано в образе. Для локального запуска при необходимости:
# TEXTS_DIR=./texts
